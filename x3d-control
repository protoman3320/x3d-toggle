#!/bin/bash
#X3D-Control v0.6.1_beta - x3d-control
#Copyright (C) 2026 Pyrotiger

TARGET=$(ls /sys/devices/platform/AMDI*/amd_x3d_mode 2>/dev/null | head -n 1)
SERVICE_NAME="x3d-auto"

if [ -z "$TARGET" ] || [ ! -f "$TARGET" ]; then
    kdialog --error "AMD X3D vCache interface not found. Check UEFI/Kernel settings or insert an actual X3D with v-Cache technology."
    exit 1
fi

CURRENT_MODE=$(cat "$TARGET" | tr -d '[:space:]')
DAEMON_STATUS=$(systemctl --user is-active "$SERVICE_NAME" --quiet && echo "RUNNING" || echo "STOPPED")

# UI Selection
RAW_CHOICE=$(kdialog --title "AMD X3D VCACHE Technology Control" --radiolist \
    "Hardware: <font color='#ff6d00'><b>${CURRENT_MODE^^}</b></font> | Daemon: <font color='#00ff00'><b>$DAEMON_STATUS</b></font><br><br>Select Mode:" \
    "cache" "Rabbit Mode (Gaming/Low Latency - CCD0)" $([[ "$CURRENT_MODE" =~ ^cache ]] && echo "on" || echo "off") \
    "frequency" "Cheetah Mode (LLM/Raw Compute - CCD1)" $([[ "$CURRENT_MODE" =~ ^frequency ]] && echo "on" || echo "off") \
    "auto" "Default (Manual Kernel CPPC Control)" $([[ "$CURRENT_MODE" =~ ^auto ]] && echo "on" || echo "off") \
    "restart_daemon" "Restart/Enable Automation Daemon" "off")

[ -z "$RAW_CHOICE" ] && exit 0

case "$RAW_CHOICE" in
    "cache"|"frequency"|"auto")
        MODE="$RAW_CHOICE"
        if systemctl --user is-active --quiet "$SERVICE_NAME"; then
            systemctl --user stop "$SERVICE_NAME"
            notify-send "X3D Control" "Manual mode engaged. Automation Daemon paused."
        fi
        ;;
    "restart_daemon")
        systemctl --user enable --now "$SERVICE_NAME"
        notify-send "X3D Control" "Automation Daemon restarted and enabled."
        exit 0
        ;;
esac

if pkexec /usr/libexec/x3d-apply "$MODE"; then
    ICON_PATH="/usr/share/x3d-toggle/ryzen.jpeg"
    DISPLAY_ICON=$([ -f "$ICON_PATH" ] && echo "file://$ICON_PATH" || echo "cpu")

    notify-send -i "$DISPLAY_ICON" "AMD X3D VCACHE Technology: ${MODE^^}" "Hardware Mode Engaged."
else
    kdialog --error "Hardware write failed. Check permissions or kernel support."
fi
