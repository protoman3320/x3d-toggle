#Copyright (C) 2026 Pyrotiger

TARGET=$(ls /sys/devices/platform/AMDI*/amd_x3d_mode 2>/dev/null | head -n 1)
STEAM_DATA="$HOME/.local/share/Steam/steamapps"

check_gaming_intent() {
    gamemoded -s | grep -q "active" && return 0

    if [ -d "$STEAM_DATA" ]; then
        pgrep -f "reaper|Proton|wine-preloader" > /dev/null && return 0
    fi

    TOP_PROC=$(ps -eo comm --sort=-%cpu | head -n 2 | tail -n 1)
    if grep -rl "Categories=.*Game" /usr/share/applications/ | xargs grep -q "Exec=.*$TOP_PROC" 2>/dev/null; then
        return 0
    fi
    return 1
}

check_compute_intent() {
    LOAD=$(awk '{print $1}' /proc/loadavg)
    (( $(echo "$LOAD > 8.0" | bc -l) )) && return 0
    return 1
}

while true; do
    if check_gaming_intent; then
        NEW_MODE="cache"
    elif check_compute_intent; then
        NEW_MODE="frequency"
    else
        NEW_MODE="frequency"
    fi

    CURRENT=$(cat "$TARGET" 2>/dev/null)
    if [[ "$CURRENT" != "$NEW_MODE" ]]; then
        pkexec /usr/libexec/x3d-apply "$NEW_MODE"
    fi
    sleep 3
done
